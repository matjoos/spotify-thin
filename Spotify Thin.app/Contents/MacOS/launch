#!/bin/bash

# Source shell profile to get PATH (npx, node, etc.)
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.nvm/versions/node/$(ls $HOME/.nvm/versions/node 2>/dev/null | tail -1)/bin:$PATH"
[ -f "$HOME/.zshrc" ] && source "$HOME/.zshrc" 2>/dev/null
[ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc" 2>/dev/null

# Navigate to the project directory
cd "/Users/mattijsjoosten/Code/spotify-thin"

# Kill any existing server on port 5173
lsof -ti:5173 | xargs kill 2>/dev/null
sleep 0.5

# Start the preview server in the background
npx vite preview --host 127.0.0.1 --port 5173 &
SERVER_PID=$!

# Wait for server to be ready
for i in {1..30}; do
  curl -s http://127.0.0.1:5173 > /dev/null 2>&1 && break
  sleep 0.5
done

# Open in Firefox
open "http://127.0.0.1:5173"

# Keep running until server exits
wait $SERVER_PID
